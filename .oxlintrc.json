{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "typescript", "react", "react-perf", "unicorn", "oxc"],
  "env": { "browser": true },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-console": "warn",
    "typescript/no-explicit-any": "error",
    "react/react-in-jsx-scope": "off"
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "vendor",
    "drizzle",
    "*.gen.ts",
    ".output",
    ".nitro",
    ".vinxi",
    ".tanstack",
    "src/components/ui"
  ],
  "settings": {
    "react": { "version": "19" }
  }
}
