{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "arrowParens": "always",
  "bracketSpacing": true,
  "sortImports": {},
  "sortTailwindcss": {},
  "ignorePatterns": [
    "dist",
    "node_modules",
    "vendor",
    "drizzle",
    "*.gen.ts",
    ".output",
    ".nitro",
    ".vinxi",
    ".tanstack",
    "bun.lock"
  ]
}
